{
  "services": [
    {
      "name": "beanstalkd",
      "description": "Beanstalkd work queue",
      "image": "docker.io/schickling/beanstalkd:latest",
      "category": "messaging",
      "icon": "queue"
    },
    {
      "name": "elasticsearch",
      "description": "Elasticsearch single-node search and analytics engine",
      "image": "docker.elastic.co/elasticsearch/elasticsearch:8.13.4",
      "category": "search",
      "icon": "search"
    },
    {
      "name": "elasticvue",
      "description": "Elasticvue web UI for the lerd Elasticsearch service",
      "dashboard": "http://localhost:8083",
      "depends_on": [
        "elasticsearch"
      ],
      "image": "docker.io/cars10/elasticvue:latest",
      "category": "admin",
      "icon": "search",
      "admin_for": [
        "elasticsearch"
      ]
    },
    {
      "name": "gotenberg",
      "description": "Gotenberg API for PDF generation and document conversion",
      "image": "docker.io/gotenberg/gotenberg:8",
      "category": "mail",
      "icon": "mail"
    },
    {
      "name": "mariadb",
      "description": "MariaDB (MySQL-compatible) versions",
      "family": "mariadb",
      "versions": [
        {
          "tag": "12",
          "label": "12 (latest)",
          "image": "docker.io/library/mariadb:12",
          "host_port": 3306
        },
        {
          "tag": "12.3",
          "label": "12.3 LTS",
          "image": "docker.io/library/mariadb:12.3",
          "host_port": 3306
        },
        {
          "tag": "11.8",
          "label": "11.8 LTS",
          "image": "docker.io/library/mariadb:11.8",
          "host_port": 3306
        },
        {
          "tag": "11.4",
          "label": "11.4 LTS",
          "image": "docker.io/library/mariadb:11.4",
          "host_port": 3306
        },
        {
          "tag": "11",
          "label": "11 (legacy)",
          "image": "docker.io/library/mariadb:11",
          "host_port": 3306
        },
        {
          "tag": "10.11",
          "label": "10.11 LTS",
          "image": "docker.io/library/mariadb:10.11",
          "host_port": 3306
        }
      ],
      "default_version": "11.8",
      "category": "databases",
      "icon": "database"
    },
    {
      "name": "memcached",
      "description": "Memcached in-memory key/value cache",
      "image": "docker.io/library/memcached:1.6-alpine",
      "category": "cache",
      "icon": "bolt"
    },
    {
      "name": "mongo",
      "description": "MongoDB document database",
      "image": "docker.io/library/mongo:7",
      "category": "databases",
      "icon": "leaf"
    },
    {
      "name": "mongo-express",
      "description": "Mongo Express web UI for the lerd MongoDB service",
      "dashboard": "http://localhost:8082",
      "depends_on": [
        "mongo"
      ],
      "image": "docker.io/library/mongo-express:latest",
      "category": "admin",
      "icon": "leaf",
      "admin_for": [
        "mongo"
      ]
    },
    {
      "name": "opensearch",
      "description": "OpenSearch single-node search and analytics engine",
      "image": "docker.io/opensearchproject/opensearch:2.19.5",
      "category": "search",
      "icon": "search"
    },
    {
      "name": "opensearch-dashboards",
      "description": "OpenSearch Dashboards web UI for the lerd OpenSearch service",
      "dashboard": "http://localhost:8086",
      "depends_on": [
        "opensearch"
      ],
      "image": "docker.io/opensearchproject/opensearch-dashboards:2.19.5",
      "category": "admin",
      "icon": "search",
      "admin_for": [
        "opensearch"
      ]
    },
    {
      "name": "pgadmin",
      "description": "pgAdmin web UI for the lerd Postgres service",
      "dashboard": "http://localhost:8081",
      "depends_on": [
        "postgres"
      ],
      "image": "docker.io/dpage/pgadmin4:latest",
      "category": "admin",
      "icon": "elephant",
      "admin_for": [
        "postgres",
        "postgres-pgvector",
        "postgres-timescaledb"
      ]
    },
    {
      "name": "phpmyadmin",
      "description": "phpMyAdmin web UI for every installed lerd MySQL service",
      "dashboard": "http://localhost:8080",
      "depends_on": [
        "mysql"
      ],
      "image": "docker.io/library/phpmyadmin:latest",
      "category": "admin",
      "icon": "database",
      "admin_for": [
        "mysql",
        "mariadb"
      ]
    },
    {
      "name": "postgres-pgvector",
      "description": "PostgreSQL with pgvector (vector embeddings, no PostGIS)",
      "family": "postgres",
      "versions": [
        {
          "tag": "18",
          "label": "18 (default)",
          "image": "docker.io/pgvector/pgvector:pg18",
          "host_port": 5432,
          "canonical": true
        },
        {
          "tag": "17",
          "label": "17",
          "image": "docker.io/pgvector/pgvector:pg17",
          "host_port": 5432
        },
        {
          "tag": "16",
          "label": "16",
          "image": "docker.io/pgvector/pgvector:pg16",
          "host_port": 5432
        }
      ],
      "default_version": "18",
      "category": "databases",
      "icon": "elephant"
    },
    {
      "name": "postgres-timescaledb",
      "description": "PostgreSQL with TimescaleDB (time-series extension)",
      "family": "postgres",
      "versions": [
        {
          "tag": "17",
          "label": "17 (default)",
          "image": "docker.io/timescale/timescaledb:latest-pg17",
          "host_port": 5432,
          "canonical": true
        },
        {
          "tag": "16",
          "label": "16",
          "image": "docker.io/timescale/timescaledb:latest-pg16",
          "host_port": 5432
        }
      ],
      "default_version": "17",
      "category": "databases",
      "icon": "elephant"
    },
    {
      "name": "rabbitmq",
      "description": "RabbitMQ message broker with management UI",
      "dashboard": "http://localhost:15672",
      "image": "docker.io/library/rabbitmq:3-management-alpine",
      "category": "messaging",
      "icon": "queue"
    },
    {
      "name": "redisinsight",
      "description": "RedisInsight web UI for the lerd Redis service",
      "dashboard": "http://localhost:8085",
      "depends_on": [
        "redis"
      ],
      "image": "docker.io/redis/redisinsight:latest",
      "category": "admin",
      "icon": "database",
      "admin_for": [
        "redis",
        "valkey"
      ]
    },
    {
      "name": "selenium",
      "description": "Selenium + Chromium for browser testing (Laravel Dusk, Symfony Panther, etc.)",
      "dashboard": "http://localhost:7900/?autoconnect=1&resize=scale",
      "image": "docker.io/selenium/standalone-chromium:latest",
      "category": "testing",
      "icon": "browserPlay"
    },
    {
      "name": "soketi",
      "description": "Soketi realtime WebSocket server (Pusher-compatible)",
      "image": "quay.io/soketi/soketi:1.6-16-alpine",
      "category": "messaging",
      "icon": "broadcast"
    },
    {
      "name": "stripe-mock",
      "description": "Local Stripe API mock for Cashier and webhook testing",
      "image": "docker.io/stripemock/stripe-mock:latest",
      "category": "testing",
      "icon": "card"
    },
    {
      "name": "typesense",
      "description": "Typesense search engine",
      "family": "typesense",
      "image": "docker.io/typesense/typesense:30.2",
      "category": "search",
      "icon": "search"
    },
    {
      "name": "typesense-dashboard",
      "description": "Typesense Dashboard web UI for the lerd Typesense service",
      "dashboard": "http://localhost:8084",
      "depends_on": [
        "typesense"
      ],
      "image": "docker.io/bfritscher/typesense-dashboard:latest",
      "category": "admin",
      "icon": "search",
      "admin_for": [
        "typesense"
      ]
    },
    {
      "name": "valkey",
      "description": "Valkey in-memory store (Redis-compatible)",
      "family": "valkey",
      "image": "docker.io/valkey/valkey:9-alpine",
      "category": "cache",
      "icon": "bolt"
    }
  ]
}
